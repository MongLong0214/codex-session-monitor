{
  "name": "codex-session-monitor",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "description": "로컬 Codex 메인·서브 에이전트 세션 모니터",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start:legacy": "node server.mjs",
    "test": "node --test --test-concurrency=1",
    "test:unit": "node --test test/session-data.test.mjs",
    "test:e2e": "node --test --test-concurrency=1 test/e2e.test.mjs",
    "test:vitest": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check": "node --check server.mjs && node --check lib/session-data.mjs && node --check public/app.js && node --check test/e2e.test.mjs",
    "astryx": "node node_modules/@astryxdesign/cli/bin/astryx.mjs"
  },
  "dependencies": {
    "@astryxdesign/core": "0.1.4",
    "@astryxdesign/theme-neutral": "0.1.4",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.14.5",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astryxdesign/cli": "0.1.4",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "29.1.1",
    "playwright": "1.61.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
